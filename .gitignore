# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test, type-check, and lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Flask runtime data
instance/

# Local secrets and environment files
.env
.env.*
*.env
*.pem
*.key
*.crt

# Runtime data directory — contains the token database with HMAC secrets
data/

# Local databases and logs (catch-all in case db is placed elsewhere)
*.db
*.sqlite
*.sqlite3
*.log

# Editor and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db